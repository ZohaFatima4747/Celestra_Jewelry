PORT=1000
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>
JWT_SECRET=<strong-random-secret-32-chars-min>

MAIL_USER=your_gmail@gmail.com
MAIL_PASS=your_gmail_app_password

# Optional: N8N automation webhook
N8N_WEBHOOK_URL=https://your-n8n-instance/webhook/<id>

# Admin seed credentials (used only by: node createAdmin.js)
ADMIN_NAME=Celestra Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<strong-password>
